async function obtenerVendedores() {
    const conn = await mysql.createConnection(dbConfig);
    const [rows] = await conn.execute("SELECT DISTINCT vendedor FROM tab_clientes WHERE vendedor != ''");
    await conn.end();
    return rows;
}

async function obtenerZonas() {
    const conn = await mysql.createConnection(dbConfig);
    const [rows] = await conn.execute("SELECT DISTINCT zona FROM tab_clientes WHERE zona != ''");
    await conn.end();
    return rows;
}

async function obtenerClientesMarketing(filtros) {
    const conn = await mysql.createConnection(dbConfig);
    let sql = "SELECT * FROM tab_clientes WHERE celular IS NOT NULL AND celular != ''";
    let params = [];
    if (filtros.vendedor) { sql += " AND vendedor = ?"; params.push(filtros.vendedor); }
    if (filtros.zona) { sql += " AND zona = ?"; params.push(filtros.zona); }
    const [rows] = await conn.execute(sql, params);
    await conn.end();
    return rows;
}

